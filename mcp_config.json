{
  "mcpServers": {
    "image-scoring": {
      "command": "python",
      "args": [
        "-m",
        "modules.mcp_server"
      ],
      "env": {
        "PYTHONPATH": "d:\\Projects\\image-scoring"
      }
    },
    "image-scoring-webui": {
      "url": "http://localhost:7860/mcp/sse"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "firebird-admin": {
      "command": "python",
      "args": [
        "-m",
        "modules.mcp_server_firebird"
      ],
      "env": {
        "PYTHONPATH": "d:\\Projects\\image-scoring"
      }
    }
  }
}