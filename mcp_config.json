{
  "mcpServers": {
    "imgscore-py-stdio": {
      "command": "python",
      "args": [
        "-m",
        "modules.mcp_server"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    "imgscore-py-sse": {
      "url": "http://127.0.0.1:7860/mcp/sse"
    },
    "imgscore-py-playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "imgscore-py-firebird-admin": {
      "command": "python",
      "args": [
        "-m",
        "modules.mcp_server_firebird"
      ],
      "env": {
        "PYTHONPATH": "d:\\Projects\\image-scoring-backend"
      }
    }
  }
}
