{
  "mcpServers": {
    "imgscore-py-stdio": {
      "command": "python",
      "args": [
        "-m",
        "modules.mcp_server"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    "imgscore-py-sse": {
      "url": "http://127.0.0.1:7860/mcp/sse",
      "disabled": true
    },
    "imgscore-py-playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "disabled": true
    },
    "imgscore-py-firebird-admin": {
      "command": "python",
      "args": [
        "-m",
        "modules.mcp_server_firebird"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "d:\\Projects\\image-scoring-backend"
      }
    },
    "imgscore-py-postgres": {
      "command": "d:\\Projects\\image-scoring-backend\\tools\\toolbox.exe",
      "args": ["--prebuilt", "postgres", "--stdio"],
      "env": {
        "POSTGRES_HOST": "127.0.0.1",
        "POSTGRES_PORT": "5432",
        "POSTGRES_DATABASE": "image_scoring",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "postgres"
      },
      "disabled": true
    }
  }
}
