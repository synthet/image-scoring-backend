{
  "mcpServers": {
    "imgscore-py-stdio": {
      "command": "python",
      "args": ["-m", "modules.mcp_server"],
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONPATH": "${workspaceFolder}" }
    },
    "imgscore-py-sse": {
      "url": "http://127.0.0.1:7860/mcp/sse"
    },
    "imgscore-py-postgres": {
      "command": "tools/toolbox.exe",
      "cwd": "${workspaceFolder}",
      "args": ["--prebuilt", "postgres", "--stdio"],
      "env": {
        "POSTGRES_HOST": "127.0.0.1",
        "POSTGRES_PORT": "5432",
        "POSTGRES_DATABASE": "image_scoring",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "postgres"
      }
    }
  }
}
