{
  "test_key": "test_value",
  "scoring_input_path": "/path/to/your/photos",
  "tagging_input_path": "",
  "stacks_input_path": "/path/to/your/photos",
  "scoring": {
    "force_rescore_default": false,
    "default_sort_by": "score_general",
    "default_sort_order": "desc"
  },
  "processing": {
    "prep_queue_size": 50,
    "scoring_queue_size": 10,
    "result_queue_size": 50,
    "clustering_batch_size": 32
  },
  "clustering": {
    "stack_representative_strategy": "score",
    "best_image_alpha": 0.65,
    "default_threshold": 0.15,
    "default_time_gap": 120,
    "force_rescan_default": false
  },
  "culling": {
    "default_threshold": 0.15,
    "default_time_gap": 120,
    "auto_export_default": false
  },
  "ui": {
    "gallery_page_size": 50,
    "default_export_format": "json"
  },
  "tagging": {
    "overwrite_default": false,
    "captions_default": true,
    "max_new_tokens": 50,
    "clip_model": "openai/clip-vit-base-patch32"
  },
  "culling_input_path": "/path/to/your/photos",
  "database": {
    "host": "localhost",
    "port": 5432,
    "dbname": "musiq",
    "user": "musiq",
    "password": "musiq",
    "pool_min": 1,
    "pool_max": 10
  },
  "system": {
    "allowed_paths": [
      "D:/",
      "/mnt/"
    ],
    "log_dir": ".cursor"
  },
  "raw_conversion": {
    "method": "rawpy_half",
    "max_resolution": 512,
    "jpeg_quality": 85
  },
  "embedding_map": {
    "enabled": false,
    "method": "umap",
    "n_neighbors": 30,
    "min_dist": 0.1,
    "max_points": 50000
  }
}